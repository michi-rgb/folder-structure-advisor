# Azure OpenAI（LLM 提案を使う場合のみ）。認証は Azure CLI（az login）で行うため
# API キーは不要です。事前に以下を済ませてください:
#   1) az login          （必要なら az login --tenant <tenant-id>）
#   2) 対象の Azure OpenAI リソースで自分に「Cognitive Services OpenAI User」ロールを付与
#
# PowerShell 例:
#   $env:AZURE_OPENAI_ENDPOINT   = "https://<resource>.openai.azure.com/"
#   $env:AZURE_OPENAI_DEPLOYMENT = "<deployment-name>"   # モデル名ではなくデプロイ名

AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<deployment-name>

# 任意（既定: 2024-10-21）
# AZURE_OPENAI_API_VERSION=2024-10-21

# 非推奨: 設定するとキー認証にフォールバックします（CLI 認証が使えない環境向け）
# AZURE_OPENAI_API_KEY=
