# LLM補助を使う場合のみ設定します。未設定でもアプリはルールベースで完全に動作します。
# プロバイダは --llm-provider {auto,azure,mistral} で選択（既定 auto = 揃っている方を使用）。

# ===== Azure OpenAI =====
# PowerShell 例:
#   $env:AZURE_OPENAI_ENDPOINT   = "https://<resource>.openai.azure.com/"
#   $env:AZURE_OPENAI_API_KEY    = "<api-key>"
#   $env:AZURE_OPENAI_DEPLOYMENT = "<deployment-name>"
#   $env:AZURE_OPENAI_API_VERSION= "2024-10-21"
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<api-key>
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

# ===== Mistral =====
# PowerShell 例:
#   $env:MISTRAL_API_KEY = "<api-key>"
#   $env:MISTRAL_MODEL   = "mistral-large-latest"   # 省略可
MISTRAL_API_KEY=<api-key>
MISTRAL_MODEL=mistral-large-latest
# MISTRAL_BASE_URL=  # 自ホスト / Azure AI 上の Mistral を使う場合のみ
